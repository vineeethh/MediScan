# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/MediScan?retryWrites=true&w=majority

# Server Configuration
PORT=3001
NODE_ENV=development
DB_NAME=MediScan

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8000

# JWT Secret — generate a strong random string (min 32 chars)
JWT_SECRET=your_strong_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# AI Provider — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# NLP Service (runs locally)
NLP_SERVICE_URL=http://localhost:5001

# Hospital Search — SerpAPI (https://serpapi.com/)
GOOGLE_MAPS_API_KEY=your_serpapi_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Firebase — Client SDK (used by frontend)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase — Admin SDK (used by backend to verify Firebase tokens)
# From: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
